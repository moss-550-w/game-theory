    "@visx/shape": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "d3": "^7.9.0",
    "framer-motion": "^11.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1",
    "zod": "^3.23.8"
